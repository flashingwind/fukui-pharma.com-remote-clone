---
import { MenuLeftIsland } from '../components/MenuLeftIsland.jsx';

export interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
  currentSection?: string;
  allPages?: { collection: string; id: string; urlSlug: string }[];
}

const { title = '福井薬局 | ビタミン・ミネラル情報', description = '', currentSlug = '', currentSection = '', allPages = [] } = Astro.props;
const site = Astro.site || new URL('https://fukui-pharma.com');
const canonicalURL = new URL(Astro.url.pathname, site);
const ogDescription = description || 'ビタミン vitamin ミネラル mineral 福井薬局 サプリメント 栄養療法 免疫 ベータグルカン メガフード';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="福井薬局" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://fukui-pharma.com/taitorf.gif" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
  </head>
  <body>
    <div class="app-shell">
      <MenuLeftIsland client:only="react" currentSlug={currentSlug} currentSection={currentSection} allPages={allPages} />
      <section id="center">
        <slot />
      </section>
    </div>
  </body>
</html>

<style is:global>
  body {
    background: #f5deb3;
    font-family: 'MS UI Gothic', 'Meiryo', sans-serif;
    color: navy;
    margin: 0;
    padding: 0;
  }

  a {
    color: #0000ee;
    text-decoration: underline;
  }

  .app-shell {
    display: flex;
    align-items: flex-start;
    min-height: 100vh;
  }

  #center {
    background: #f5deb3;
    margin: 0;
    padding: 16px 24px 24px;
    min-height: 100vh;
    min-width: 0;
    max-width: none;
    flex: 1 1 auto;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .app-shell {
      flex-direction: column;
    }
    #center {
      width: 100%;
      padding: 14px 14px 20px;
      min-height: auto;
    }
  }
</style>
