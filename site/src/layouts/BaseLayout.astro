---
import { MenuLeftIsland } from '../components/MenuLeftIsland.jsx';

export interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
  currentSection?: string;
  allPages?: { collection: string; id: string; urlSlug: string }[];
}

const { title = 'Fukui Pharma', description = '', currentSlug = '', currentSection = '', allPages = [] } = Astro.props;
const site = Astro.site || new URL('https://fukui-pharma.com');
const canonicalURL = new URL(Astro.url.pathname, site);
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <div class="app-shell">
      <MenuLeftIsland client:only="react" currentSlug={currentSlug} currentSection={currentSection} allPages={allPages} />
      <section id="center">
        <slot />
      </section>
    </div>
  </body>
</html>

<style is:global>
  body {
    background: #f5deb3;
    font-family: 'MS UI Gothic', 'Meiryo', sans-serif;
    color: navy;
    margin: 0;
    padding: 0;
  }

  a {
    color: #0000ee;
    text-decoration: underline;
  }

  .app-shell {
    display: flex;
    align-items: flex-start;
    min-height: 100vh;
  }

  #center {
    background: #f5deb3;
    margin: 0;
    padding: 16px 24px 24px;
    min-height: 100vh;
    min-width: 0;
    max-width: none;
    flex: 1 1 auto;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .app-shell {
      flex-direction: column;
    }
    #center {
      width: 100%;
      padding: 14px 14px 20px;
      min-height: auto;
    }
  }
</style>
