---
import BaseLayout from './BaseLayout.astro';
import '../styles/MarkdownContent.css';

export interface Props {
  frontmatter: {
    title?: string;
    description?: string;
  };
  slug?: string;
  section?: string;
  allPages?: { collection: string; id: string; urlSlug: string }[];
}

const { frontmatter, slug = '', section = '', allPages = [] } = Astro.props;
const pageTitle = frontmatter.title ? `${frontmatter.title} 福井薬局 | ビタミン・ミネラル情報` : '福井薬局 | ビタミン・ミネラル情報';
---

<BaseLayout
  title={pageTitle}
  description={frontmatter.description}
  currentSlug={slug}
  currentSection={section}
  allPages={allPages}
>
  <div class="markdown-body">
    <slot />
  </div>
</BaseLayout>
