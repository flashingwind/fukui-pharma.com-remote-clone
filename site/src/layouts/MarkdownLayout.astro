---
import BaseLayout from './BaseLayout.astro';
import '../styles/MarkdownContent.css';

export interface Props {
  frontmatter: {
    title?: string;
    description?: string;
  };
  slug?: string;
  section?: string;
  allPages?: { collection: string; id: string; urlSlug: string }[];
}

const { frontmatter, slug = '', section = '', allPages = [] } = Astro.props;
const SITE_NAME = '福井薬局 | ビタミン・ミネラル情報';
const pageTitle = frontmatter.title && frontmatter.title !== '福井薬局'
  ? `${frontmatter.title} | ${SITE_NAME}`
  : SITE_NAME;
---

<BaseLayout
  title={pageTitle}
  description={frontmatter.description}
  currentSlug={slug}
  currentSection={section}
  allPages={allPages}
>
  <div class="markdown-body">
    <slot />
  </div>
  <footer class="site-footer">
    <div class="footer-credit">(C)2022 Fukui Pharamacy., (C)2012 福井透. 2012/2/12最終更新.</div>
  </footer>
</BaseLayout>

<style is:global>
  .site-footer {
    margin-top: 14px;
    padding: 16px 0 10px;
    border-top: 1px solid #c8b38a;
    color: #7a2000;
    font-size: 11px;
  }
</style>
