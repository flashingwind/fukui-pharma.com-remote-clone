---
import { marked } from 'marked';
import fs from 'fs';
import path from 'path';
import MarkdownLayout from '../layouts/MarkdownLayout.astro';

const indexMd = fs.readFileSync(path.join(process.cwd(), 'src/content/index.md'), 'utf-8');
const htmlContent = await marked(indexMd);
---

<MarkdownLayout
  frontmatter={{ title: '福井薬局', description: 'ビタミン、ミネラルの情報。ベータグルカン、メガフードなどサプリメントのご紹介、栄養療法、免疫のしくみの説明。' }}
>
  <Fragment set:html={htmlContent} />
</MarkdownLayout>
