---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import MarkdownLayout from '../layouts/MarkdownLayout.astro';

const COLLECTIONS = [
  'vitamin-mineral',
  'nutrient-foods',
  'supplement',
  'active-oxygen',
  'atopic',
  'flowers',
  'travel',
  'others',
  'shop',
  'access',
];

export async function getStaticPaths() {
  const COLLECTIONS = [
    'vitamin-mineral',
    'nutrient-foods',
    'supplement',
    'active-oxygen',
    'atopic',
    'flowers',
    'travel',
    'others',
    'shop',
    'access',
  ];

  // 全ページのURLリストをビルド
  const allPages = [];
  for (const collection of COLLECTIONS) {
    try {
      const entries = await getCollection(collection);
      for (const entry of entries) {
        const entrySlug = entry.slug || entry.id;
        if (entrySlug && entrySlug !== 'index') {
          allPages.push({ collection, id: entry.id, urlSlug: `${collection}/${entrySlug}` });
        }
      }
    } catch (e) {}
  }

  const paths = [];
  for (const collection of COLLECTIONS) {
    try {
      const entries = await getCollection(collection);
      for (const entry of entries) {
        const entrySlug = entry.slug || entry.id;
        if (entrySlug && entrySlug !== 'index') {
          paths.push({
            params: { slug: `${collection}/${entrySlug}` },
            props: { entry, collection, allPages },
          });
        }
      }
    } catch (e) {}
  }

  return paths;
}

interface Props {
  entry: any;
  collection: string;
  allPages: { collection: string; id: string; urlSlug: string }[];
}

const { entry, collection, allPages } = Astro.props;
const htmlContent = await marked(entry.body);

const section = collection;
const slug = entry.id.split('/').pop();

// frontmatterにtitleがなければ本文冒頭のh1から自動取得
const titleMatch = entry.body.match(/^#{1,3}\s+(.+)/m);
const title = entry.data.title ?? (titleMatch ? titleMatch[1].replace(/<[^>]+>/g, '').trim() : undefined);

// frontmatterにdescriptionがなければ本文冒頭から自動生成
const description = entry.data.description ?? (() => {
  const text = entry.body
    .replace(/^#+\s+.*/gm, '')
    .replace(/\[Image\][^\n]*/g, '')
    .replace(/<[^>]+>/g, '')
    .replace(/!?\[([^\]]*)\]\([^)]*\)/g, '$1')
    .replace(/^[-*>|=]{2,}\s*$/gm, '')
    .replace(/^[-*>|]\s*/gm, '')
    .replace(/[`_*]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  return text.slice(0, 120) || undefined;
})();
---

<MarkdownLayout
  frontmatter={{ ...entry.data, title, description }}
  slug={slug}
  section={section}
  allPages={allPages}
>
  <Fragment set:html={htmlContent} />
</MarkdownLayout>
