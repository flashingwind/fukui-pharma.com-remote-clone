---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import MarkdownLayout from '../layouts/MarkdownLayout.astro';

export async function getStaticPaths() {
  const allCollections = [
    'vitamin-mineral',
    'supplement',
    'active-oxygen',
    'atopic',
    'flowers',
    'travel',
    'others',
    'shop',
    'access',
  ];

  const paths = [];

  for (const collection of allCollections) {
    try {
      const entries = await getCollection(collection);
      if (entries && Array.isArray(entries)) {
        for (const entry of entries) {
          // Use id as slug if slug doesn't exist
          const slug = entry.slug || entry.id;
          if (slug && slug !== 'index') {
            paths.push({
              params: { slug: slug },
              props: { entry },
            });
          }
        }
      }
    } catch (e) {
      console.error(`Error loading collection`, e.message);
    }
  }

  return paths;
}

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const htmlContent = await marked(entry.body);

// Extract section from entry ID (e.g., "vitamin-mineral/nutrient-foods/aenganyu" -> "vitamin-mineral")
const idParts = entry.id.split('/');
const section = idParts.length > 1 ? idParts[0] : entry.id;
const slug = entry.id.split('/').pop();

// frontmatterにdescriptionがなければ本文冒頭から自動生成
const description = entry.data.description ?? (() => {
  const text = entry.body
    .replace(/^#+\s+.*/gm, '')                   // 見出しを除去
    .replace(/\[Image\][^\n]*/g, '')              // [Image]プレースホルダを除去
    .replace(/<[^>]+>/g, '')                      // HTMLタグを除去
    .replace(/!?\[([^\]]*)\]\([^)]*\)/g, '$1')   // リンク・画像をテキスト化
    .replace(/^[-*>|=]{2,}\s*$/gm, '')             // 水平線・markdown記号行を除去
    .replace(/^[-*>|]\s*/gm, '')                   // 行頭のmarkdown記号を除去
    .replace(/[`_*]/g, '')
    .replace(/\s+/g, ' ')                         // 空白を正規化
    .trim();
  return text.slice(0, 120) || undefined;
})();
---

<MarkdownLayout
  frontmatter={{ ...entry.data, description }}
  slug={slug}
  section={section}
>
  <Fragment set:html={htmlContent} />
</MarkdownLayout>
